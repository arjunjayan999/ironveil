{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"strict": true,

		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,

		"verbatimModuleSyntax": true,
		"isolatedModules": true,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		"skipLibCheck": true
	}
}
